    "text": "Original-Wortlaut historisch erhalten.",
    "canton": "BE",
    "source_url": "https://www.belex.sites.be.ch/data/271.1/de",
    "effective_date": "1996-01-01",
    "repealed_date": "9999-12-31"
  },
  {
