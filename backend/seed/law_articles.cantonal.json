    "eli_uri": "cantonal:BE:271.1",
    "sr_number": "271.1",
    "article": "1",
    "paragraph": "1",
    "language": "de",
    "text": "Diese Verordnung regelt das Verfahren vor den Schlichtungsbehörden in Mietsachen.",
    "canton": "BE",
    "source_url": "https://www.belex.sites.be.ch/data/271.1/de",
    "effective_date": "1996-01-01",
    "repealed_date": null
  },
  {
    "eli_uri": "cantonal:BE:271.1",
    "sr_number": "271.1",
    "article": "11",
    "paragraph": "1",
    "language": "de",
    "text": "Die Schlichtungsbehörde versucht, eine Einigung zwischen Vermieterin und Mieter herbeizuführen.",
    "canton": "BE",
    "source_url": "https://www.belex.sites.be.ch/data/271.1/de",
    "effective_date": "1996-01-01",
    "repealed_date": null
  },
  {
    "eli_uri": "cantonal:BE:271.1",
    "sr_number": "271.1",
    "article": "11",
    "paragraph": "2",
    "language": "de",
    "text": "Gelingt keine Einigung, so fällt sie einen Entscheid oder erteilt der Klägerin eine Klagebewilligung.",
    "canton": "BE",
    "source_url": "https://www.belex.sites.be.ch/data/271.1/de",
    "effective_date": "1996-01-01",
    "repealed_date": null
  },
  {
    "eli_uri": "cantonal:BE:271.1",
    "sr_number": "271.1",
    "article": "11",
    "paragraph": "3",
    "language": "de",
    "text": "Das Verfahren ist kostenlos.",
    "canton": "BE",
    "source_url": "https://www.belex.sites.be.ch/data/271.1/de",
    "effective_date": "1996-01-01",
    "repealed_date": null
  },
  {
